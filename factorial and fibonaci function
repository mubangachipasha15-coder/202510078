# Factorial function
def factorial(n):
    if n == 0 or n == 1:
        return 1
    result = 1
    for i in range(2, n + 1):
        result *= i
    return result


# Fibonacci function (prints first n terms)
def fibonacci(n):
    sequence = []
    a, b = 0, 1

    for _ in range(n):
        sequence.append(a)
        a, b = b, a + b

    return sequence


# Main program
num = int(input("Enter a number: "))

print("Factorial of", num, "is:", factorial(num))
print("Fibonacci sequence up to", num, "terms:", fibonacci(num))
